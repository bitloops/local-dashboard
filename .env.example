# Optional: openapi-typescript types-only generator (src/types/openapi.generated.d.ts). See scripts/generate-openapi-types.mjs
# OPENAPI_PRIMARY_URL=https://bitloops.local:5667/api/openapi.json
# OPENAPI_FALLBACK_URL=http://127.0.0.1:5667/api/openapi.json
# OPENAPI_TYPES_OUTPUT=src/types/openapi.generated.d.ts
# OPENAPI_FETCH_TIMEOUT_MS=8000
# For HTTPS with self-signed certs only; prefer NODE_EXTRA_CA_CERTS with a CA bundle when possible.
# OPENAPI_ALLOW_INSECURE_TLS=true

# Bitloops CLI API base (browser)
# VITE_BITLOOPS_CLI_BASE=http://127.0.0.1:5667

# Vite dev server: proxy /api to this origin (see vite.config.ts)
# VITE_API_PROXY_TARGET=http://bitloops.local:5667

# When the proxy target is HTTPS with an untrusted cert, set true to opt out of TLS verification for the proxy hop only.
# VITE_PROXY_ALLOW_INSECURE_TLS=true

# Query explorer: max age (ms) for persisted run history entries. Default: 30 days.
# VITE_QUERY_HISTORY_TTL_MS=
