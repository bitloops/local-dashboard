# Vite dev server: proxy /devql/dashboard and /devql/global to this origin (see vite.config.ts)
# VITE_API_PROXY_TARGET=
# Set to true to use bundled mock data for /devql/dashboard (no Bitloops backend required).
# VITE_DASHBOARD_API_MOCK=true

# Query explorer: max age (ms) for persisted run history entries (default: 2592000000 = 30 days).
# VITE_QUERY_HISTORY_TTL_MS=2592000000
